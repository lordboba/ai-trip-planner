{
  "name": "ai-trip-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": "22.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "frontend:dev": "next dev --turbopack",
    "backend:dev": "node --watch --experimental-strip-types backend/src/server.ts",
    "backend:start": "node --experimental-strip-types backend/src/server.ts",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit"
  },
  "dependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "framer-motion": "12.38.0",
    "next": "16.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwindcss": "4.2.2",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@types/node": "22.16.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.2"
  }
}
