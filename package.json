{
  "name": "ai-trip-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.19.0",
  "engines": {
    "node": "22.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "web:dev": "pnpm --filter @ai-trip-planner/web frontend:dev",
    "backend:dev": "pnpm --filter @ai-trip-planner/web backend:dev",
    "mobile:dev": "pnpm --filter @ai-trip-planner/mobile dev",
    "build": "pnpm --filter @ai-trip-planner/web build",
    "start": "pnpm --filter @ai-trip-planner/web start",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  }
}
