    "@vis.gl/react-google-maps": "1.6.1",
    "framer-motion": "12.38.0",
    "next": "16.2.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tailwindcss": "4.2.2",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@types/google.maps": "3.58.1",
    "@types/node": "22.16.0",
    "@types/react": "~19.2.10",
